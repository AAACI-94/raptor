# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional - Model overrides (defaults to recommended models per agent)
# RAPTOR_MODEL_RESEARCH=claude-sonnet-4-20250514
# RAPTOR_MODEL_STRUCTURE=claude-sonnet-4-20250514
# RAPTOR_MODEL_WRITER=claude-sonnet-4-20250514
# RAPTOR_MODEL_REVIEWER=claude-opus-4-20250514
# RAPTOR_MODEL_PRODUCTION=claude-sonnet-4-20250514
# RAPTOR_MODEL_REFLECTION=claude-haiku-4-5-20251001
# RAPTOR_MODEL_OBSERVATORY=claude-haiku-4-5-20251001

# Optional - Server
# PORT=8000
# LOG_LEVEL=INFO
# DATABASE_PATH=./data/raptor.db

# Optional - Observability
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_SERVICE_NAME=raptor

# Optional - Research Agent
# SEMANTIC_SCHOLAR_API_KEY=
# RAPTOR_RAG_MAX_ITERATIONS=3
# RAPTOR_RAG_MIN_SOURCES=5

# Optional - Pipeline
# RAPTOR_MAX_REVISION_CYCLES=3
# RAPTOR_REFLECTION_ENABLED=true
