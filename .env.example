# RAPTOR v1.2.0 Environment Configuration
# No API keys required. Uses Claude CLI (keychain auth) + Ollama (local).

# Optional - AI Provider
# RAPTOR_PROVIDER=auto    # "auto" (default), "claude-cli", "ollama"
# RAPTOR_OLLAMA_MODEL=qwen3.5
# RAPTOR_OLLAMA_URL=http://localhost:11434

# Optional - Server
# PORT=8000
# LOG_LEVEL=INFO
# DATABASE_PATH=./data/raptor.db

# Optional - Observability
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_SERVICE_NAME=raptor

# Optional - Pipeline
# RAPTOR_MAX_REVISION_CYCLES=3
# RAPTOR_REFLECTION_ENABLED=true

# Optional - Self-Healing
# RAPTOR_SENTINEL_ENABLED=true
# RAPTOR_MAX_REMEDIATION_ATTEMPTS=3
